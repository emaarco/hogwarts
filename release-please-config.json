{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "separate-pull-requests": true,
  "changelog-path": "CHANGELOG.md",
  "draft": false,
  "prerelease": false,
  "packages": {
    "plugins/agento-patronum": {
      "package-name": "agento-patronum",
      "component": "agento-patronum",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/felix-felicis": {
      "package-name": "felix-felicis",
      "component": "felix-felicis",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/revelio": {
      "package-name": "revelio",
      "component": "revelio",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
